{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "bundle": {
    "targets": [
      "nsis",
      "msi"
    ],
    "windows": {
      "allowDowngrades": false,
      "digestAlgorithm": "sha256",
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "startMenuFolder": "ModernClaw",
        "compression": "lzma"
      }
    }
  }
}
