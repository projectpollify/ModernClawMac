{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ModernClawMac",
  "version": "0.1.0",
  "identifier": "com.localai.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "ModernClawMac",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:11434 http://127.0.0.1:11434 http://localhost:8080 http://127.0.0.1:8080"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "app",
      "dmg",
      "deb",
      "rpm",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "publisher": "ModernClaw",
    "shortDescription": "Local-first AI workspace for durable personal context and chat on Mac.",
    "longDescription": "ModernClawMac is a local-first desktop workspace for private AI chat, durable Markdown memory, guided setup, and on-device context management through a built-in direct engine.",
    "category": "Productivity",
    "copyright": "(c) 2026 ModernClawMac",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
